# PR Gatekeeper — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional (safe defaults already set)
GOOGLE_GENAI_USE_VERTEXAI=False

# Model to use. gemini-3.5-flash is the recommended default.
# Use gemini-3.1-flash-lite for tighter free-tier quota.
# NOTE: gemini-1.5-* and gemini-2.0-* families are retired and return 404.
GEMINI_MODEL=gemini-3.5-flash

# GitHub integration (only needed for live CI runs)
# Your GitHub personal access token (needs repo + pull_requests scope)
# Leave empty for dry-run/demo mode (no live GitHub writes)
GITHUB_TOKEN=

# Set to true to enable live GitHub writes (post comments, set check-run status).
# Leave as false during local development and demos.
GATEKEEPER_LIVE=false

# Populated automatically by GitHub Actions — do not set manually
# PR_NUMBER=
# REPO=
# BASE_SHA=
# HEAD_SHA=
